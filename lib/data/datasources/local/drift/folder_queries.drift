import 'folders.drift';
import 'decks.drift';
import 'flashcards.drift';
import 'flashcard_progress.drift';

-- Library Overview: one row per anchor folder (top-level when :search is empty,
-- else any folder whose name matches) with its recursive subtree aggregates,
-- summary hints for the mock-aligned row (subtitle / new count / mastery), and
-- the global folder/due totals. `:now` is the "due today" cutoff (UTC epoch ms);
-- `:search` is a pre-normalised LIKE pattern (e.g. '%korean%') or '' for no
-- search; `$order` is the caller-built sort. Explicit columns (no SELECT *) so
-- the generated result class is fully typed.
libraryOverview(:now AS INT, :search AS TEXT):
WITH RECURSIVE subtree(anchor_id, folder_id) AS (
  SELECT folders.id, folders.id FROM folders
  WHERE (:search = '' AND folders.parent_id IS NULL)
     OR (:search <> '' AND LOWER(folders.name) LIKE :search ESCAPE '\')
  UNION ALL
  SELECT st.anchor_id, c.id
  FROM folders AS c
  INNER JOIN subtree AS st ON c.parent_id = st.folder_id
)
SELECT
  folders.id,
  folders.parent_id,
  folders.name,
  folders.content_mode,
  folders.sort_order,
  folders.created_at,
  folders.updated_at,
  (SELECT COUNT(*) FROM subtree s
     WHERE s.anchor_id = folders.id AND s.folder_id <> folders.id)
    AS subfolder_count,
  (SELECT COUNT(*) FROM decks d
     INNER JOIN subtree s ON d.folder_id = s.folder_id
     WHERE s.anchor_id = folders.id) AS deck_count,
  (SELECT COUNT(*) FROM flashcards fc
     INNER JOIN decks d ON fc.deck_id = d.id
     INNER JOIN subtree s ON d.folder_id = s.folder_id
     WHERE s.anchor_id = folders.id) AS card_count,
  (SELECT COUNT(*) FROM flashcards fc
     INNER JOIN decks d ON fc.deck_id = d.id
     INNER JOIN subtree s ON d.folder_id = s.folder_id
     INNER JOIN flashcard_progress p ON p.flashcard_id = fc.id
     WHERE s.anchor_id = folders.id
       AND p.is_suspended = FALSE
       AND (p.buried_until IS NULL OR p.buried_until <= :now)
       AND p.due_at IS NOT NULL AND p.due_at <= :now) AS due_count,
  CASE folders.content_mode
    WHEN 'subfolders' THEN (
      SELECT GROUP_CONCAT(name, ' · ') FROM (
        SELECT c.name AS name
        FROM folders AS c
        WHERE c.parent_id = folders.id
        ORDER BY c.sort_order
        LIMIT 3
      )
    )
    WHEN 'decks' THEN (
      SELECT GROUP_CONCAT(name, ' · ') FROM (
        SELECT d.name AS name
        FROM decks AS d
        WHERE d.folder_id = folders.id
        ORDER BY d.sort_order
        LIMIT 3
      )
    )
    ELSE NULL
  END AS subtitle,
  (SELECT COUNT(*) FROM flashcards fc
     INNER JOIN decks d ON fc.deck_id = d.id
     INNER JOIN subtree s ON d.folder_id = s.folder_id
     LEFT JOIN flashcard_progress p ON p.flashcard_id = fc.id
     WHERE s.anchor_id = folders.id
       AND COALESCE(p.is_suspended, FALSE) = FALSE
       AND (p.buried_until IS NULL OR p.buried_until <= :now)
       AND (p.flashcard_id IS NULL OR p.due_at IS NULL)) AS new_count,
  (SELECT COALESCE(AVG(COALESCE(p.box_number, 1)), 0.0) / 8.0
     FROM flashcards fc
     INNER JOIN decks d ON fc.deck_id = d.id
     INNER JOIN subtree s ON d.folder_id = s.folder_id
     LEFT JOIN flashcard_progress p ON p.flashcard_id = fc.id
     WHERE s.anchor_id = folders.id) AS mastery,
  (SELECT COUNT(*) FROM folders) AS total_folder_count,
  (SELECT COUNT(*) FROM flashcards fc
     INNER JOIN flashcard_progress p ON p.flashcard_id = fc.id
     WHERE p.is_suspended = FALSE
       AND (p.buried_until IS NULL OR p.buried_until <= :now)
       AND p.due_at IS NOT NULL AND p.due_at <= :now) AS due_today_total
FROM folders
WHERE (:search = '' AND folders.parent_id IS NULL)
   OR (:search <> '' AND LOWER(folders.name) LIKE :search ESCAPE '\')
ORDER BY $order;

-- Direct child folders of :parentId with their recursive subtree counts.
subfolderItems(:parentId AS TEXT, :now AS INT, :search AS TEXT):
WITH RECURSIVE subtree(anchor_id, folder_id) AS (
  SELECT folders.id, folders.id FROM folders
  WHERE folders.parent_id = :parentId
    AND (:search = '' OR LOWER(folders.name) LIKE :search ESCAPE '\')
  UNION ALL
  SELECT st.anchor_id, c.id
  FROM folders AS c
  INNER JOIN subtree AS st ON c.parent_id = st.folder_id
)
SELECT
  folders.id,
  folders.parent_id,
  folders.name,
  folders.content_mode,
  folders.sort_order,
  folders.created_at,
  folders.updated_at,
  (SELECT COUNT(*) FROM subtree s
     WHERE s.anchor_id = folders.id AND s.folder_id <> folders.id)
    AS subfolder_count,
  (SELECT COUNT(*) FROM decks d
     INNER JOIN subtree s ON d.folder_id = s.folder_id
     WHERE s.anchor_id = folders.id) AS deck_count,
  (SELECT COUNT(*) FROM flashcards fc
     INNER JOIN decks d ON fc.deck_id = d.id
     INNER JOIN subtree s ON d.folder_id = s.folder_id
     WHERE s.anchor_id = folders.id) AS card_count,
  (SELECT COUNT(*) FROM flashcards fc
     INNER JOIN decks d ON fc.deck_id = d.id
     INNER JOIN subtree s ON d.folder_id = s.folder_id
     INNER JOIN flashcard_progress p ON p.flashcard_id = fc.id
     WHERE s.anchor_id = folders.id
       AND p.is_suspended = FALSE
       AND (p.buried_until IS NULL OR p.buried_until <= :now)
       AND p.due_at IS NOT NULL AND p.due_at <= :now) AS due_count,
  (SELECT COUNT(*) FROM flashcards fc
     INNER JOIN decks d ON fc.deck_id = d.id
     INNER JOIN subtree s ON d.folder_id = s.folder_id
     LEFT JOIN flashcard_progress p ON p.flashcard_id = fc.id
     WHERE s.anchor_id = folders.id
       AND COALESCE(p.is_suspended, FALSE) = FALSE
       AND (p.buried_until IS NULL OR p.buried_until <= :now)
       AND (p.flashcard_id IS NULL OR p.due_at IS NULL)) AS new_count
FROM folders
WHERE folders.id IN (SELECT anchor_id FROM subtree)
ORDER BY $order;

-- Direct child decks of :folderId with card + due counts.
deckItems(:folderId AS TEXT, :now AS INT, :search AS TEXT):
SELECT
  decks.id,
  decks.folder_id,
  decks.name,
  decks.target_language,
  decks.sort_order,
  decks.created_at,
  decks.updated_at,
  (SELECT COUNT(*) FROM flashcards fc WHERE fc.deck_id = decks.id) AS card_count,
  (SELECT COUNT(*) FROM flashcards fc
     INNER JOIN flashcard_progress p ON p.flashcard_id = fc.id
     WHERE fc.deck_id = decks.id
       AND p.is_suspended = FALSE
       AND (p.buried_until IS NULL OR p.buried_until <= :now)
       AND p.due_at IS NOT NULL AND p.due_at <= :now) AS due_count
  ,
  (SELECT MAX(p.last_studied_at)
     FROM flashcards fc
     LEFT JOIN flashcard_progress p ON p.flashcard_id = fc.id
     WHERE fc.deck_id = decks.id) AS last_studied_at
  ,
  (SELECT COUNT(*) FROM flashcards fc
     LEFT JOIN flashcard_progress p ON p.flashcard_id = fc.id
     WHERE fc.deck_id = decks.id
       AND COALESCE(p.is_suspended, FALSE) = FALSE
       AND (p.buried_until IS NULL OR p.buried_until <= :now)
       AND (p.flashcard_id IS NULL OR p.due_at IS NULL)) AS new_count
FROM decks
WHERE decks.folder_id = :folderId
  AND (:search = '' OR LOWER(decks.name) LIKE :search ESCAPE '\')
ORDER BY $order;

-- Folder ancestor chain root -> :id (inclusive), ordered for the breadcrumb.
folderBreadcrumb(:id AS TEXT):
WITH RECURSIVE chain(id, name, parent_id, depth) AS (
  SELECT folders.id, folders.name, folders.parent_id, 0
  FROM folders WHERE folders.id = :id
  UNION ALL
  SELECT folders.id, folders.name, folders.parent_id, chain.depth + 1
  FROM folders INNER JOIN chain ON folders.id = chain.parent_id
)
SELECT id, name FROM chain ORDER BY depth DESC;

-- Ids of :id and all its descendant folders, deepest-first so a caller can
-- delete them without violating the self-referential (RESTRICT) FK.
descendantFolderIds(:id AS TEXT):
WITH RECURSIVE subtree(folder_id, depth) AS (
  SELECT folders.id, 0 FROM folders WHERE folders.id = :id
  UNION ALL
  SELECT folders.id, subtree.depth + 1
  FROM folders INNER JOIN subtree ON folders.parent_id = subtree.folder_id
)
SELECT folder_id FROM subtree ORDER BY depth DESC;

-- A single scalar that changes whenever any content-tree table is written;
-- watched as a reactive rebuild trigger (replaces the Dart `SELECT 1` +
-- explicit `readsFrom`). Reads all four tables so Drift invalidates the stream
-- on any insert/update/delete.
contentRevision:
SELECT
  (SELECT COUNT(*) FROM folders)
  + (SELECT COUNT(*) FROM decks)
  + (SELECT COUNT(*) FROM flashcards)
  + (SELECT COUNT(*) FROM flashcard_progress) AS revision;
