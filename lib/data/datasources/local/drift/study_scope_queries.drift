import 'flashcards.drift';
import 'decks.drift';
import 'folders.drift';
import 'flashcard_progress.drift';

-- Cards in a single deck, ordered stably for a study queue.
studyDeckCards(:deckId AS TEXT):
SELECT
  flashcards.id,
  flashcard_progress.box_number,
  flashcard_progress.due_at,
  flashcard_progress.buried_until,
  flashcard_progress.is_suspended
FROM flashcards
LEFT JOIN flashcard_progress
  ON flashcard_progress.flashcard_id = flashcards.id
WHERE flashcards.deck_id = :deckId
ORDER BY flashcards.sort_order, flashcards.created_at, flashcards.id;

-- Cards in a folder subtree, ordered stably by folder depth, deck order, and
-- flashcard order.
studyFolderCards(:folderId AS TEXT):
WITH RECURSIVE subtree(folder_id, depth) AS (
  SELECT folders.id, 0
  FROM folders
  WHERE folders.id = :folderId
  UNION ALL
  SELECT folders.id, subtree.depth + 1
  FROM folders
  INNER JOIN subtree ON folders.parent_id = subtree.folder_id
)
SELECT
  flashcards.id,
  flashcard_progress.box_number,
  flashcard_progress.due_at,
  flashcard_progress.buried_until,
  flashcard_progress.is_suspended
FROM subtree
INNER JOIN decks ON decks.folder_id = subtree.folder_id
INNER JOIN flashcards ON flashcards.deck_id = decks.id
LEFT JOIN flashcard_progress
  ON flashcard_progress.flashcard_id = flashcards.id
ORDER BY subtree.depth, decks.sort_order, flashcards.sort_order,
  flashcards.created_at, flashcards.id;

-- Cards across the full library, ordered by due date then deck/card order.
studyTodayCards:
SELECT
  flashcards.id,
  flashcard_progress.box_number,
  flashcard_progress.due_at,
  flashcard_progress.buried_until,
  flashcard_progress.is_suspended
FROM flashcards
INNER JOIN decks ON decks.id = flashcards.deck_id
LEFT JOIN flashcard_progress
  ON flashcard_progress.flashcard_id = flashcards.id
ORDER BY
  CASE
    WHEN flashcard_progress.due_at IS NULL THEN 1
    ELSE 0
  END,
  flashcard_progress.due_at,
  decks.sort_order,
  flashcards.sort_order,
  flashcards.created_at,
  flashcards.id;
