import 'folders.drift';

-- `decks` table — every deck belongs to exactly one folder (cascade on folder
-- delete). `target_language` stores the `TargetLanguage` enum as lowercase text.
-- Generated row class: `DeckRow`.
CREATE TABLE decks (
  id TEXT NOT NULL PRIMARY KEY,
  folder_id TEXT NOT NULL REFERENCES folders (id) ON DELETE CASCADE,
  name TEXT NOT NULL,
  target_language TEXT NOT NULL DEFAULT 'korean',
  sort_order INTEGER NOT NULL DEFAULT 0,
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL
) AS DeckRow;
