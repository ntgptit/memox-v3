import 'flashcards.drift';

CREATE TABLE study_sessions (
  id TEXT NOT NULL PRIMARY KEY,
  entry_type TEXT NOT NULL,
  entry_ref_id TEXT,
  study_type TEXT NOT NULL,
  status TEXT NOT NULL,
  -- Ordered phase plan (StudyFlow, snake_case). Legacy rows default to the
  -- single-phase recall review flow.
  study_flow TEXT NOT NULL DEFAULT 'srs_recall_review',
  -- Active phase pointer (StudyMode, snake_case). NULL marks a legacy
  -- single-mode session resolved through the recall fallback.
  current_mode TEXT,
  started_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL
) AS StudySessionRow;

CREATE INDEX idx_study_sessions_resumable
  ON study_sessions (entry_type, entry_ref_id, status, started_at DESC);
