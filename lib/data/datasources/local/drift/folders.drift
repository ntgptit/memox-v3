-- `folders` table — self-referencing content tree (NULL parent = root).
-- Mirrors the schema in `docs/database/schema-contract.md`. The generated row
-- class is named `FolderRow` (via `AS FolderRow`) so existing Dart mappers/DAO
-- keep compiling unchanged. Self-FK is RESTRICT (subtree cleanup happens in a
-- transaction, not a cascade).
CREATE TABLE folders (
  id TEXT NOT NULL PRIMARY KEY,
  parent_id TEXT REFERENCES folders (id) ON DELETE RESTRICT,
  name TEXT NOT NULL,
  -- `ContentMode` as lowercase text: unlocked / subfolders / decks.
  content_mode TEXT NOT NULL DEFAULT 'unlocked',
  sort_order INTEGER NOT NULL DEFAULT 0,
  -- UTC epoch milliseconds.
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL
) AS FolderRow;
