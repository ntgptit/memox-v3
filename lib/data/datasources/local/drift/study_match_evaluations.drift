import 'study_session_items.drift';

CREATE TABLE study_match_evaluations (
  id TEXT NOT NULL PRIMARY KEY,
  session_id TEXT NOT NULL
    REFERENCES study_sessions (id) ON DELETE CASCADE,
  session_item_id TEXT NOT NULL
    REFERENCES study_session_items (id) ON DELETE CASCADE,
  flashcard_id TEXT NOT NULL
    REFERENCES flashcards (id) ON DELETE CASCADE,
  board_index INTEGER NOT NULL,
  pair_id TEXT NOT NULL,
  selected_front_cell_id TEXT NOT NULL,
  selected_back_cell_id TEXT NOT NULL,
  expected_front_flashcard_id TEXT NOT NULL
    REFERENCES flashcards (id) ON DELETE CASCADE,
  expected_back_flashcard_id TEXT NOT NULL
    REFERENCES flashcards (id) ON DELETE CASCADE,
  is_correct BOOLEAN NOT NULL DEFAULT FALSE,
  attempt_order INTEGER NOT NULL,
  evaluated_at INTEGER NOT NULL,
  created_at INTEGER NOT NULL,
  UNIQUE(session_id, attempt_order)
) AS StudyMatchEvaluationsRow;

CREATE INDEX idx_study_match_evaluations_session
  ON study_match_evaluations (session_id, board_index, attempt_order, evaluated_at, id);

CREATE INDEX idx_study_match_evaluations_session_item
  ON study_match_evaluations (session_item_id, board_index, attempt_order, evaluated_at, id);

studyMatchEvaluationsBySession(:sessionId AS TEXT):
SELECT
  study_match_evaluations.id,
  study_match_evaluations.session_id,
  study_match_evaluations.session_item_id,
  study_match_evaluations.flashcard_id,
  study_match_evaluations.board_index,
  study_match_evaluations.pair_id,
  study_match_evaluations.selected_front_cell_id,
  study_match_evaluations.selected_back_cell_id,
  study_match_evaluations.expected_front_flashcard_id,
  study_match_evaluations.expected_back_flashcard_id,
  study_match_evaluations.is_correct,
  study_match_evaluations.attempt_order,
  study_match_evaluations.evaluated_at,
  study_match_evaluations.created_at
FROM study_match_evaluations
WHERE study_match_evaluations.session_id = :sessionId
ORDER BY study_match_evaluations.session_id,
  study_match_evaluations.board_index,
  study_match_evaluations.attempt_order,
  study_match_evaluations.evaluated_at,
  study_match_evaluations.id;
