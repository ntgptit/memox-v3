import 'study_session_items.drift';

CREATE TABLE study_attempts (
  id TEXT NOT NULL PRIMARY KEY,
  session_item_id TEXT NOT NULL
    REFERENCES study_session_items (id) ON DELETE CASCADE,
  result TEXT NOT NULL,
  study_mode TEXT NOT NULL,
  box_before INTEGER NOT NULL DEFAULT 0,
  box_after INTEGER NOT NULL DEFAULT 0,
  user_input TEXT,
  -- Time spent on the card before grading, ms. NULL = not measured (older rows /
  -- non-timed flows); the Card History timeline shows "duration not logged".
  duration_ms INTEGER,
  attempted_at INTEGER NOT NULL
) AS StudyAttemptRow;

CREATE INDEX idx_study_attempts_session_item
  ON study_attempts (session_item_id, attempted_at DESC);

studySessionAttempts(:sessionId AS TEXT):
SELECT
  study_attempts.id,
  study_attempts.session_item_id,
  study_attempts.result,
  study_attempts.study_mode,
  study_attempts.box_before,
  study_attempts.box_after,
  study_attempts.user_input,
  study_attempts.attempted_at,
  study_session_items.flashcard_id,
  study_session_items.sort_order
FROM study_attempts
INNER JOIN study_session_items
  ON study_session_items.id = study_attempts.session_item_id
WHERE study_session_items.session_id = :sessionId
ORDER BY study_session_items.sort_order,
  study_attempts.attempted_at,
  study_attempts.id;
