-- Flashcards: a single card belonging to exactly one deck. deck_id uses
-- ON DELETE CASCADE so deleting a deck removes its cards (and, via the cascade
-- chain below, their progress + tag rows). front/back are the required content
-- fields (non-empty after trim, enforced in the repository); example_sentence,
-- pronunciation, and hint are optional notes stored as NULL when blank.
-- Timestamps are UTC epoch milliseconds; ids are text (UUID-like). See
-- docs/database/schema-contract.md §flashcards and
-- docs/business/flashcard/flashcard-management.md.
CREATE TABLE flashcards (
  id TEXT NOT NULL PRIMARY KEY,
  deck_id TEXT NOT NULL REFERENCES decks (id) ON DELETE CASCADE,
  front TEXT NOT NULL,
  back TEXT NOT NULL,
  example_sentence TEXT,
  pronunciation TEXT,
  hint TEXT,
  sort_order INTEGER NOT NULL,
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL
) AS FlashcardRow;

CREATE INDEX idx_flashcards_deck ON flashcards (deck_id);

-- SRS scheduling state, 1:1 with flashcards (flashcard_id is both PK and FK with
-- ON DELETE CASCADE). A brand-new card starts in box 1 with due_at = NULL (NEW
-- until first studied) and zeroed counters. box_number / due_at / review_count /
-- lapse_count are only mutated by the study/SRS path, never the editor.
-- is_suspended (default false) and buried_until (default NULL) hold the bury/
-- suspend state added in schema v4 (WBS 4.0.2). A card is suspended when
-- is_suspended is true; currently buried when buried_until is a future epoch-ms
-- timestamp. No behavior reads them yet — the queue-exclusion / status-filter
-- eligibility logic lands later (WBS 4.11.1 / 2.17.1).
CREATE TABLE flashcard_progress (
  flashcard_id TEXT NOT NULL PRIMARY KEY REFERENCES flashcards (id) ON DELETE CASCADE,
  box_number INTEGER NOT NULL DEFAULT 1,
  due_at INTEGER,
  review_count INTEGER NOT NULL DEFAULT 0,
  lapse_count INTEGER NOT NULL DEFAULT 0,
  is_suspended BOOLEAN NOT NULL DEFAULT 0,
  buried_until INTEGER
) AS FlashcardProgressRow;

-- Per-card tags (0..N), stored lowercased + trimmed (case-insensitive identity).
-- flashcard_id uses ON DELETE CASCADE. idx_flashcard_tags_tag supports tag
-- lookups; the (flashcard_id, tag) PK enforces per-card uniqueness.
CREATE TABLE flashcard_tags (
  flashcard_id TEXT NOT NULL REFERENCES flashcards (id) ON DELETE CASCADE,
  tag TEXT NOT NULL,
  PRIMARY KEY (flashcard_id, tag)
) AS FlashcardTagRow;

CREATE INDEX idx_flashcard_tags_tag ON flashcard_tags (tag);
