import 'decks.drift';

-- `flashcards` table — belongs to exactly one deck (cascade on deck delete).
-- SRS scheduling lives in the sibling `flashcard_progress` row.
-- Generated row class: `FlashcardRow`.
CREATE TABLE flashcards (
  id TEXT NOT NULL PRIMARY KEY,
  deck_id TEXT NOT NULL REFERENCES decks (id) ON DELETE CASCADE,
  -- Term / prompt side.
  front TEXT NOT NULL,
  -- Meaning / answer side.
  back TEXT NOT NULL,
  -- Optional example sentence shown on the back.
  example_sentence TEXT,
  -- Optional pronunciation hint.
  pronunciation TEXT,
  -- Optional mnemonic hint.
  hint TEXT,
  -- Optional grammatical part of speech (e.g. 'noun', 'verb'); shown as a chip on
  -- the list + editor. Free text, normalized lowercase. NULL = none.
  part_of_speech TEXT,
  -- User flag for quick filtering (Flagged pill on the list). Default false.
  is_flagged BOOLEAN NOT NULL DEFAULT FALSE,
  sort_order INTEGER NOT NULL DEFAULT 0,
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL
) AS FlashcardRow;
