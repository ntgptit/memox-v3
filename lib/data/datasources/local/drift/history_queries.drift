import 'flashcards.drift';
import 'flashcard_progress.drift';
import 'study_attempts.drift';
import 'study_session_items.drift';
import 'study_sessions.drift';
import 'card_events.drift';

-- Card History header: card preview + current SRS state + lifetime counters +
-- last reset marker. `flashcard_progress` is LEFT JOIN'd so a never-studied card
-- still returns its preview (progress columns come back NULL).
-- See `docs/business/history/card-history.md`, `docs/wireframes/09-flashcard-history.md`.
cardHistoryHeader(:flashcard_id AS TEXT):
SELECT
  flashcards.id AS flashcard_id,
  flashcards.deck_id,
  flashcards.front,
  flashcards.back,
  flashcards.created_at,
  flashcard_progress.box_number,
  flashcard_progress.due_at,
  flashcard_progress.buried_until,
  flashcard_progress.is_suspended,
  flashcard_progress.review_count,
  flashcard_progress.lapse_count,
  flashcard_progress.last_reset_at
FROM flashcards
LEFT JOIN flashcard_progress
  ON flashcard_progress.flashcard_id = flashcards.id
WHERE flashcards.id = :flashcard_id;

-- All attempts for a card, newest first, for the unified activity feed (merged
-- with `card_events` in Dart). Per-card scale is small, so the feed loads fully
-- and terminates with a "Beginning of history" marker — no offset pagination.
cardHistoryAttempts(:flashcard_id AS TEXT):
SELECT
  study_attempts.id,
  study_attempts.result,
  study_attempts.study_mode,
  study_attempts.box_before,
  study_attempts.box_after,
  study_attempts.duration_ms,
  study_attempts.attempted_at,
  study_session_items.session_id,
  study_sessions.status AS session_status
FROM study_attempts
INNER JOIN study_session_items
  ON study_session_items.id = study_attempts.session_item_id
INNER JOIN study_sessions
  ON study_sessions.id = study_session_items.session_id
WHERE study_session_items.flashcard_id = :flashcard_id
ORDER BY study_attempts.attempted_at DESC, study_attempts.id DESC;

-- All lifecycle events for a card (created / edited / audio added), newest first.
cardHistoryCardEvents(:flashcard_id AS TEXT):
SELECT
  card_events.id,
  card_events.type,
  card_events.occurred_at,
  card_events.detail
FROM card_events
WHERE card_events.flashcard_id = :flashcard_id
ORDER BY card_events.occurred_at DESC, card_events.id DESC;

-- Attempt results newest-first, for the "correct streak" computation
-- (leading run of non-`forgot` results). Read-only; counters are not scanned.
cardHistoryResultsDesc(:flashcard_id AS TEXT):
SELECT study_attempts.result
FROM study_attempts
INNER JOIN study_session_items
  ON study_session_items.id = study_attempts.session_item_id
WHERE study_session_items.flashcard_id = :flashcard_id
ORDER BY study_attempts.attempted_at DESC, study_attempts.id DESC;
