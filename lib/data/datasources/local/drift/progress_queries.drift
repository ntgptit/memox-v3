import 'decks.drift';
import 'flashcards.drift';
import 'study_tables.drift';

-- Progress due-summary aggregate (WBS 7.1.1). Counts due cards per deck,
-- EXCLUDING suspended and currently-buried cards, mirroring the study-queue
-- exclusion (WBS 4.11.1, study_scope_queries.drift) and the eligibility counts
-- (WBS 4.1.1) so every "due" surface agrees:
--   due            : due_at IS NOT NULL AND due_at <= :now
--   suspended      : COALESCE(is_suspended, 0) = 1            → excluded
--   currently buried: buried_until IS NOT NULL AND buried_until > :now → excluded
-- A missing flashcard_progress row (LEFT JOIN → NULLs) is a NEW card with no
-- due_at, so it is never counted as due. The INNER JOIN on flashcards + the WHERE
-- due filter mean only decks with at least one due card form a group, so every
-- returned row already has due_count >= 1 (no HAVING needed). The global total is
-- the sum of the per-deck counts (every flashcard belongs to exactly one deck via
-- a NOT NULL FK).

dueCountsByDeck(:now AS INT):
SELECT
  d.id AS deck_id,
  d.name AS deck_name,
  COUNT(fc.id) AS due_count
FROM decks d
JOIN flashcards fc ON fc.deck_id = d.id
LEFT JOIN flashcard_progress fp ON fp.flashcard_id = fc.id
WHERE COALESCE(fp.is_suspended, 0) = 0
  AND (fp.buried_until IS NULL OR fp.buried_until <= :now)
  AND fp.due_at IS NOT NULL AND fp.due_at <= :now
GROUP BY d.id, d.name
ORDER BY due_count DESC, d.name ASC, d.id ASC;

-- Box distribution (WBS 7.2.1): card counts per Leitner box from the current
-- `flashcard_progress` table. Every flashcard has a progress row from creation
-- (flashcard.md C1), so a brand-new card counts in box 1. The repository
-- zero-fills boxes 1..8 and fails fast on any out-of-range `box_number`
-- (decision row P9).
boxDistribution:
SELECT box_number, COUNT(*) AS card_count
FROM flashcard_progress
GROUP BY box_number
ORDER BY box_number ASC;

-- Study statistics (WBS 7.3.1; decision row P10). Pure read aggregates, no
-- mutation. Completed-session count and the attempt rollup are separate reads.
completedSessionCount:
SELECT COUNT(*) AS c FROM study_sessions WHERE status = 'completed';

-- total attempts, forgot (lapse) outcomes, and the most recent attempt time.
-- correct = total - forgot is derived in the repository. last_studied_at is
-- NULL when no attempts exist (MAX over an empty set).
attemptStatistics:
SELECT
  COUNT(*) AS total,
  COALESCE(SUM(CASE WHEN result = 'forgot' THEN 1 ELSE 0 END), 0) AS forgot
FROM study_attempts;

-- Most recent attempt time; a direct column select so drift infers `int`. Empty
-- table → no row → null in the repository.
lastAttemptTime:
SELECT attempted_at FROM study_attempts ORDER BY attempted_at DESC LIMIT 1;

-- Stats "Cards this week" (docs/wireframes/18-stats.md): the raw attempt
-- timestamps from :start onward (the current local week's Monday midnight,
-- passed as a UTC epoch-ms absolute). A direct single-column select so drift
-- infers `List<int>`; the repository buckets them into local days in Dart
-- (toLocal()) — NEVER 'localtime' in SQL (the test sqlite returns NULL for it).
attemptsSince(:start AS INT):
SELECT attempted_at FROM study_attempts
WHERE attempted_at >= :start
ORDER BY attempted_at ASC;

-- Stats "Per-deck mastery" (docs/wireframes/18-stats.md): the average Leitner
-- box per deck over `flashcard_progress` (every flashcard has a progress row
-- from creation, so a brand-new card counts in box 1). The INNER JOINs mean
-- only decks with at least one card form a group. The repository maps avg_box →
-- a 0..1 mastery fraction. Ordered by deck name for a stable scan.
deckMastery:
SELECT
  d.id AS deck_id,
  d.name AS deck_name,
  AVG(fp.box_number) AS avg_box,
  COUNT(fp.flashcard_id) AS card_count
FROM decks d
JOIN flashcards fc ON fc.deck_id = d.id
JOIN flashcard_progress fp ON fp.flashcard_id = fc.id
GROUP BY d.id, d.name
ORDER BY d.name ASC, d.id ASC;
