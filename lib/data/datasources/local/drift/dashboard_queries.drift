import 'flashcards.drift';
import 'study_tables.drift';
import 'decks.drift';
import 'folders.drift';
import 'card_events.drift';

-- Dashboard "Continue studying" read model (WBS 5.1.1). The single most recently
-- active resumable session across ALL scopes (status draft/in_progress,
-- `updated_at` within the 30-day window passed as :cutoff), with its answered /
-- total item progress and the scope's display name. `answered_items` counts
-- non-NULL `answered_at`. `scope_name` resolves read-only: the deck name for a
-- `deck` scope, the folder name for a `folder` scope, NULL for the global
-- `today` scope (entry_ref_id IS NULL → the FE renders a localized label). The
-- name joins are 1:1 on the scope's `entry_ref_id`, so they do not fan out the
-- per-session item COUNTs. Returns no row when there is no resumable session.
-- See docs/business/resume/resume-session.md + docs/business/engagement/dashboard-engagement.md.
dashboardResumeSession(:cutoff AS INT):
SELECT
  s.id AS id,
  s.entry_type AS entry_type,
  s.entry_ref_id AS entry_ref_id,
  s.study_type AS study_type,
  s.updated_at AS updated_at,
  COUNT(i.id) AS total_items,
  COUNT(i.answered_at) AS answered_items,
  COALESCE(d.name, f.name) AS scope_name
FROM study_sessions s
LEFT JOIN study_session_items i ON i.session_id = s.id
LEFT JOIN decks d ON s.entry_type = 'deck' AND d.id = s.entry_ref_id
LEFT JOIN folders f ON s.entry_type = 'folder' AND f.id = s.entry_ref_id
WHERE s.status IN ('draft', 'in_progress') AND s.updated_at > :cutoff
GROUP BY s.id
ORDER BY s.updated_at DESC
LIMIT 1;

-- Dashboard summary read model (WBS 5.x — design redesign). One row with the
-- count of cards currently due and the number of distinct decks holding them.
-- "Due" matches the folder_queries semantics: a scheduled card whose due_at has
-- passed (`due_at IS NOT NULL AND due_at <= :now`); NEW cards (due_at IS NULL)
-- are not due. Per decision row F13 the count also EXCLUDES suspended
-- (`COALESCE(is_suspended,0)=1`) and currently-buried (`buried_until > :now`)
-- cards, mirroring `folder_queries.drift` and the canonical
-- `study_scope_queries.drift` predicate (bury-suspend.md §238: all due-count
-- surfaces exclude them).
dashboardDueSummary:
SELECT
  COUNT(*) AS cards_due,
  COUNT(DISTINCT f.deck_id) AS decks_with_due
FROM flashcard_progress fp
JOIN flashcards f ON f.id = fp.flashcard_id
WHERE COALESCE(fp.is_suspended, 0) = 0
  AND (fp.buried_until IS NULL OR fp.buried_until <= :now)
  AND fp.due_at IS NOT NULL AND fp.due_at <= :now;

-- Dashboard engagement stat strip (WBS 5.x): total number of decks (the "Decks"
-- metric in the overview stat strip, distinct from `decks_with_due`). See
-- docs/business/engagement/dashboard-engagement.md.
dashboardDeckCount:
SELECT COUNT(*) AS total FROM decks;

-- Dashboard engagement "Recent decks" list (WBS 5.x): decks the user has studied,
-- most-recently-studied first, with card count, current due count, and the last
-- study timestamp. "Studied" = has at least one `card_events` row (a review/study
-- event); never-studied decks are excluded. `due_count` reuses the canonical due
-- predicate from `dashboardDueSummary` (excludes suspended/buried, NEW cards are
-- not due). Capped by :limit. See docs/business/engagement/dashboard-engagement.md.
dashboardRecentDecks(:now AS INT, :limit AS INT):
SELECT
  d.id AS id,
  d.name AS name,
  (SELECT COUNT(*) FROM flashcards fc WHERE fc.deck_id = d.id) AS card_count,
  MAX(ce.occurred_at) AS last_studied_at,
  (
    SELECT COUNT(*)
    FROM flashcard_progress fp
    JOIN flashcards f2 ON f2.id = fp.flashcard_id
    WHERE f2.deck_id = d.id
      AND COALESCE(fp.is_suspended, 0) = 0
      AND (fp.buried_until IS NULL OR fp.buried_until <= :now)
      AND fp.due_at IS NOT NULL AND fp.due_at <= :now
  ) AS due_count
FROM decks d
JOIN flashcards f ON f.deck_id = d.id
JOIN card_events ce ON ce.flashcard_id = f.id
GROUP BY d.id
ORDER BY last_studied_at DESC
LIMIT :limit;
