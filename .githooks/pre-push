#!/bin/sh
# pre-push — auto-sync MemoX kit changes to Claude Design v3 (standing rule, PO 2026-06-24).
#
# When a push includes any change under the kit (docs/system-design/MemoX Design
# System/ui_kits/**), push that change up to the Claude Design project so the canonical
# design never drifts. This only fires when the kit actually changed (a cheap git diff
# guard) — normal pushes spawn nothing.
#
# Requires a `claude` CLI that has run /design-login (only that carries design-system
# auth; the sync is not CI-able). NON-FATAL: a failed sync warns but never blocks the
# push — drift is still caught by `design_watch --check` and a manual
# `node tool/parity/sync-design.mjs`. Disable entirely with MEMOX_NO_DESIGN_SYNC=1.
[ "$MEMOX_NO_DESIGN_SYNC" = "1" ] && exit 0

ZERO="0000000000000000000000000000000000000000"
KIT="docs/system-design/MemoX Design System/ui_kits"
done_sync=0

while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$ZERO" ] && continue   # branch deletion — nothing to sync
  [ "$done_sync" = "1" ] && continue        # one sync per push is enough

  if [ "$remote_sha" = "$ZERO" ]; then
    # New remote branch: narrow to commits not on origin/main if possible.
    from=$(git merge-base origin/main "$local_sha" 2>/dev/null)
    [ -z "$from" ] && from=$(git rev-parse "$local_sha~1" 2>/dev/null)
  else
    from="$remote_sha"
  fi
  [ -z "$from" ] && continue

  if git diff --name-only "$from" "$local_sha" -- "$KIT" | grep -q .; then
    echo "pre-push: kit changed → syncing to Claude Design v3 (MEMOX_NO_DESIGN_SYNC=1 to skip)…"
    if node tool/parity/sync-design.mjs "$from" --no-record; then
      done_sync=1
    else
      echo "pre-push: WARNING — design sync failed; push continues. Re-run: node tool/parity/sync-design.mjs $from" >&2
    fi
  fi
done

exit 0
