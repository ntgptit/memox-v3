#!/bin/sh
# MemoX pre-commit hook — enforces the single-entry verification process.
#
# A commit is allowed ONLY when `node tool/verify/run.mjs` has PASSED on the
# exact current content of the tree (the run writes a state-bound pass-marker).
# Running verification commands piecemeal produces no marker → commit blocked.
# Editing any file after a PASS invalidates the marker → re-run verify.
#
# Activate once per clone:  git config core.hooksPath .githooks
# Bypass in emergencies:    git commit --no-verify  (must be justified in the report)

command -v node >/dev/null 2>&1 || { echo "pre-commit: node not found, skipping verify-marker check"; exit 0; }

node tool/verify/run.mjs --check-marker || {
  echo ""
  echo "pre-commit BLOCKED: run the single verification entry, then commit:"
  echo "  docs-only change:  node tool/verify/run.mjs --docs"
  echo "  code change:       node tool/verify/run.mjs --test <targeted test paths>"
  exit 1
}

git diff --cached --check || {
  echo "pre-commit BLOCKED: whitespace errors in staged changes."
  exit 1
}

exit 0
