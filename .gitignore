# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# Vendored nested repository; commit and push from code-verification-guard/ itself.
/code-verification-guard/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/
test/**/failures/

# build_runner generated sources
*.g.dart
*.freezed.dart
*.drift.dart

# flutter gen-l10n output
lib/l10n/generated/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Local packaging artifacts
/*.zip
/*.apk
/*.aab
/*.ipa
/*.msix
/*.appinstaller

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Flutter generated registrants
**/generated_plugin_registrant.dart

# UI kit screenshot exporter
tool/ui_kit_shots/node_modules/
tool/ui_kit_shots/package-lock.json
tool/verify/.last-pass.json

# Claude Code agent worktrees (internal tool state — not project files)
# but DO track shared sub-agent definitions in .claude/agents/
.claude/*
!.claude/agents/
